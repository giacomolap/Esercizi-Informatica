def conta_frequenza(testo):
    frequenze = {}
    lista_parole = testo.split()
    for parola in lista_parole:
        if parola in frequenze:
            frequenze[parola] = frequenze[parola] + 1
        else:
            frequenze[parola] = 1
    return frequenze            

print(conta_frequenza("Ciao mi chiamo Giacomo Lapietra, ma tutti mi chiamano Giacomo"))
